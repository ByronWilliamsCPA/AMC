# Frontend Environment Configuration
# Copy this file to .env.local for local development

# =============================================================================
# API Configuration
# =============================================================================

# The app ALWAYS calls the API at the relative, same-origin path `/api` so the
# HTTP-only session cookie is sent. Do NOT point the app at an absolute
# cross-origin URL — that breaks SameSite=Lax cookie auth.
#
# This variable only sets the DEV proxy target (where Vite forwards `/api` and
# `/health` during `npm run dev`); it does not change the app's request URLs.
VITE_DEV_API_TARGET=http://localhost:8000

# =============================================================================
# Feature Flags (optional)
# =============================================================================

# Enable debug mode (shows additional logging)
# VITE_DEBUG=false

# =============================================================================
# Third-Party Services (optional)
# =============================================================================

# Analytics tracking ID
# VITE_ANALYTICS_ID=

# Sentry DSN for frontend error tracking
# VITE_SENTRY_DSN=
